# ── WalletConnect ────────────────────────────────────
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# ── Deploy (Hardhat) ─────────────────────────────────
PRIVATE_KEY=your_deployer_wallet_private_key

# ── Hedera ────────────────────────────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=0xYourDeployedContractAddress
NEXT_PUBLIC_RPC_URL=https://testnet.hashio.io/api

# ── Pinata / IPFS ────────────────────────────────────
